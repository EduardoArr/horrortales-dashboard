# Postgres (Neon). DATABASE_URL is the pooled connection used at runtime,
# DIRECT_URL is the direct connection used for migrations.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# YouTube Data API v3 key (Google Cloud Console, YouTube Data API v3 enabled)
YOUTUBE_API_KEY="your-api-key-here"

# NextAuth (Auth.js) — generate with: npx auth secret
AUTH_SECRET="generate-with-npx-auth-secret"

# Shared secret required in the Authorization header of the Vercel Cron request
CRON_SECRET="generate-a-random-string"

# Set to "true" to make lib/discovery/youtubeClient.ts read from
# lib/discovery/__fixtures__ instead of calling the real YouTube API.
YOUTUBE_MOCK="false"

# Anthropic API (separate pay-per-use key, NOT the ChatGPT/Claude subscription).
# Create at https://console.anthropic.com/settings/keys — requires adding a payment method.
ANTHROPIC_API_KEY="your-api-key-here"

# Model used for título/miniatura generation. Vision-capable models only
# (reference-thumbnail reverse-engineering needs to see the image).
ANTHROPIC_MODEL="claude-sonnet-5"

# Set to "true" to make lib/thumbnails/anthropicClient.ts read from
# lib/thumbnails/__fixtures__ instead of calling the real Anthropic API.
ANTHROPIC_MOCK="false"

# Vercel Blob (host photo library storage). Requires `vercel link` first,
# then Vercel dashboard -> Storage -> Create Database -> Blob.
BLOB_READ_WRITE_TOKEN="vercel-blob-rw-token-here"

# Used once by `npm run db:seed` to create the 2 fixed accounts.
SEED_USER1_EMAIL="owner1@example.com"
SEED_USER1_PASSWORD="change-me"
SEED_USER1_NAME="Owner 1"
SEED_USER2_EMAIL="owner2@example.com"
SEED_USER2_PASSWORD="change-me"
SEED_USER2_NAME="Owner 2"
